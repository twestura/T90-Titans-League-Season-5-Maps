/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

#const PHON 1543
#const PHONL 1544

/* Middle Gold Placement */
#const GOLD_T1 rnd(0,359)
#const GOLD_OFFSET rnd(-15,15)
#const GOLD_T2 (GOLD_T1 + 180 + GOLD_OFFSET)
#const GOLD_R 5
#FOR($i, 1, 3)
	#TRIG(GOLD_T$i)
	#const GOLD_X$i (GOLD_R * COS_GOLD_T$i + 60)
	#const GOLD_Y$i (GOLD_R * SIN_GOLD_T$i + 60)
#END_FOR

/* Herdable constants, Sheep near the TC, Goats far away for visibility. */
