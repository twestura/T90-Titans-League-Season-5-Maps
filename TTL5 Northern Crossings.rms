/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
	random_placement

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

	#define PRELIMINARIES
	if PRELIMINARIES
		if LEGACY_CODE
		else
			behavior_version 1
		endif
	
		if EW_TESTING
			#define EMPIRE_WARS
			#define FEUDAL_AGE_START
			#define EW_FEUDAL /* Phase Out */
		else
			if NOMAD_MAP
				#define NOMAD_START
			endif
		endif
	
		if EMPIRE_WARS
			if DARK_AGE_START
				#define EW_DARK
				effect_amount MOD_RESOURCE AMOUNT_STARTING_WOOD ATTR_ADD -30
				effect_amount MOD_RESOURCE AMOUNT_STARTING_FOOD ATTR_ADD -100
				effect_amount GAIA_ADD_ATTRIBUTE HERDABLE_A ATTR_STORAGE_VALUE -30	
				effect_amount GAIA_SET_ATTRIBUTE HERDABLE_A ATTR_HITPOINTS 0
				#const EW_REVEALER 851 /* ES Flag */
				effect_amount SET_ATTRIBUTE EW_REVEALER ATTR_LINE_OF_SIGHT 18
				effect_amount SET_ATTRIBUTE EW_REVEALER ATTR_HITPOINTS 0
			elseif FEUDAL_AGE_START
				#define EW_FEUDAL
			elseif CASTLE_AGE_START
				#define EW_CASTLE
			elseif IMPERIAL_AGE_START
				#define EW_IMPERIAL
			elseif POST_IMPERIAL_AGE_START
				#define EW_POST
			else
				#define EW_DEFAULT
			endif
		endif
	
		if NOMAD_START
			nomad_resources
	
			if ENABLE_TREATY
				force_nomad_treaty
			endif
		endif
	
		if REGICIDE_BUILDING
			#define FAR_MONASTERY
		endif
	
		if CENTRALISE_SPAWN
			if RESTRICTED_SPAWN
				#define CENTRALISE_OBJECT
			else
				if NOMAD_START
					if REGICIDE_BUILDING
