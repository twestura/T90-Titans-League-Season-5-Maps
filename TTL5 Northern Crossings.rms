<LAND_GENERATION>
	base_terrain BASE_PLACEHOLDER
	enable_waves 1

	create_land
	{
		terrain_type ISLAND_TERRAIN
		land_percent 100
		base_size 7
		top_border 44
		left_border 44
		right_border 44
		bottom_border 44
		base_elevation 0
		land_position 50 50
		land_id 420
	}

