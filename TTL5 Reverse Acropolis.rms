    number_of_tiles 1465
    clumping_factor 30
    other_zone_avoidance_distance 22
    zone $i
    if TB
      top_border -10
      right_border 21
      bottom_border -10
      left_border 20
    elseif LR
      top_border 20
      right_border -10
      bottom_border 21
      left_border -10
    endif
  }
#END_FOR */

create_land {
  land_position X1 Y1
  terrain_type T_PLAYER1
  assign_to AT_TEAM -10 0 0
  zone 1
  base_size 8
  number_of_tiles 1465
  clumping_factor 30
  other_zone_avoidance_distance 22
  if TB
    top_border 77
    right_border 21
    bottom_border -10
    left_border 20
  elseif LR
    top_border 20
    right_border 78
    bottom_border 21
    left_border -10
  endif
}

create_land {
  land_position X2 Y2
  terrain_type T_PLAYER2
  assign_to AT_TEAM -10 0 0
  zone 2
  base_size 8
  number_of_tiles 1465
  clumping_factor 30
  other_zone_avoidance_distance 22
  if TB
    top_border -10
    right_border 21
    bottom_border 78
    left_border 20
  elseif LR
    top_border 20
    right_border -10
    bottom_border 21
    left_border 77
  endif
}

if FOREST_DIRECT
  #FOR($i, 1, 3)
    create_land {
      land_position U$i V$i
      base_elevation 7
      terrain_type FOREST
      number_of_tiles 80
      set_circular_base
      base_size 3
      zone $i
      other_zone_avoidance_distance 0
    }
  #END_FOR
elseif FOREST_SPLIT
  create_land { land_position A11 B11 zone 1 terrain_type FOREST base_elevation 7 number_of_tiles 60 set_circular_base base_size 3 other_zone_avoidance_distance 0 }
  create_land { land_position A12 B12 zone 1 terrain_type FOREST base_elevation 7 number_of_tiles 60 set_circular_base base_size 3 other_zone_avoidance_distance 0 }
  create_land { land_position A21 B21 zone 2 terrain_type FOREST base_elevation 7 number_of_tiles 60 set_circular_base base_size 3 other_zone_avoidance_distance 0 }
  create_land { land_position A22 B22 zone 2 terrain_type FOREST base_elevation 7 number_of_tiles 60 set_circular_base base_size 3 other_zone_avoidance_distance 0 }
endif

<ELEVATION_GENERATION>
/*
 * The create elevation command must be repeated many times to ensure the
 * elevation spawns. This repetition has a significant performance impact upon
 * the map's generation time.
 */
#REPEAT(256)
  create_elevation 7 {
    base_terrain DLC_ROCK
    enable_balanced_elevation
    number_of_tiles 14400
    number_of_clumps 14400
  }
#END_REPEAT

<TERRAIN_GENERATION>
/* Replaces the middle pond. */
create_terrain WATER {
  base_terrain SNOW
  number_of_tiles 65
  spacing_to_other_terrain_types 2
}

#REPEAT(8)
  create_terrain DLC_ROCK {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Water masking. */
create_terrain WATER_MASK {
  base_terrain WATER
  spacing_to_other_terrain_types 1
  terrain_mask 1
  number_of_tiles 35
  number_of_clumps 7
}

/* Per-player Forests */
#FOR($i, 1, 3)
  create_terrain BOTTOM_FOREST {
    base_terrain T_PLAYER$i
    number_of_tiles 85
    number_of_clumps 8
    set_scale_by_groups
    set_avoid_player_start_areas
    spacing_to_other_terrain_types 1
  }
#END_FOR

/* Makes both players have the same base terrain. */
#FOR($i, 1, 3)
  create_terrain BOTTOM_TERRAIN {
    base_terrain T_PLAYER$i
    land_percent 100
    number_of_clumps 8192
  }
#END_FOR

/* Remove tiles of rock at bottoms of the plateaus, away from the sides. */
#REPEAT(8)
  create_terrain SNOW {
    base_terrain DLC_ROCK
    land_percent 100
    number_of_clumps 8192
    height_limits 0 0
  }
#END_REPEAT

#REPEAT(8)
  create_terrain BOTTOM_TERRAIN {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DLC_ROCK {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Replaces the rock at the top. */
#REPEAT(8)
  create_terrain TOP_TERRAIN {
    base_terrain DLC_ROCK
    land_percent 100
    number_of_clumps 8192
    height_limits 7 7
    beach_terrain SHORE
  }
#END_REPEAT

/* Global forests on the top of the map. */
create_terrain ROAD {
  base_terrain TOP_TERRAIN
  land_percent 6
  number_of_clumps 9
  clumping_factor 40
  set_scale_by_groups
  set_avoid_player_start_areas
  spacing_to_other_terrain_types 3
  spacing_to_specific_terrain WATER 8
  spacing_to_specific_terrain FOREST 11
  spacing_to_specific_terrain DLC_ROCK 6
}
#REPEAT(8)
  create_terrain TOP_FOREST_MAIN {
    base_terrain ROAD
    land_percent 100
    number_of_clumps 8192
  }
  create_terrain TOP_FOREST_MAIN {
    base_terrain FOREST
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Top Forest Masking */
#REPEAT(6)
  create_terrain TOP_FOREST_SECOND {
    base_terrain TOP_FOREST_MAIN
    land_percent 100
  }
#END_REPEAT

if SNOW_LIGHT
  create_terrain TOP_FOREST_MAIN {
    base_terrain TOP_FOREST_SECOND
    number_of_tiles 360
    number_of_clumps 360
  }
  create_terrain TOP_FOREST_SECOND {
    base_terrain TOP_FOREST_MAIN
    number_of_tiles 64
    number_of_clumps 64
  }
  create_terrain SNOW_FOREST {
    base_terrain BOTTOM_FOREST
    number_of_tiles 32
    number_of_clumps 32
  }
elseif SNOW_HEAVY
  create_terrain DLC_FORESTDEAD {
    base_terrain TOP_FOREST_MAIN
    number_of_tiles 128
    number_of_clumps 128
  }
  create_terrain DLC_FORESTDEAD {
    base_terrain TOP_FOREST_SECOND
    number_of_tiles 128
    number_of_clumps 128
  }
endif

/* Terrain Masking */
create_terrain BOTTOM_MASK_1 {
  base_terrain BOTTOM_TERRAIN
  land_percent 2
  number_of_clumps 8
  terrain_mask 1
}

create_terrain BOTTOM_MASK_2 {
  base_terrain BOTTOM_TERRAIN
  land_percent 1
  number_of_clumps 8
  terrain_mask 1
}

create_terrain TOP_MASK_1 {
  base_terrain TOP_TERRAIN
  land_percent 12
  number_of_clumps 16
  spacing_to_specific_terrain DLC_ROCK 3
  spacing_to_specific_terrain WATER 5
  terrain_mask 1
}

create_terrain TOP_MASK_2 {
  base_terrain TOP_TERRAIN
  land_percent 5
  number_of_clumps 8
  spacing_to_specific_terrain DLC_ROCK 3
  spacing_to_specific_terrain WATER 5
  terrain_mask 1
}

create_terrain TOP_MASK_3 {
  base_terrain TOP_TERRAIN
  land_percent 5
  number_of_clumps 8
  spacing_to_specific_terrain DLC_ROCK 3
  spacing_to_specific_terrain WATER 5
  terrain_mask 1
}

/* Masks the bottoms and tops of the slopes. */
#REPEAT(8)
  create_terrain BOTTOM_TERRAIN {
    base_terrain DLC_ROCK
    land_percent 100
    number_of_clumps 8192
    /*
     * Isolate only the base tile at the bottom.
     * The ground already is cleared of Rock.
     */
    height_limits 0 0
    terrain_mask 2
  }
#END_REPEAT

#REPEAT(8)
  create_terrain TOP_TERRAIN {
    base_terrain DLC_ROCK
    land_percent 100
    number_of_clumps 8192
    /* Isolate only a single tile at the top. */
    spacing_to_specific_terrain BOTTOM_TERRAIN 5
    terrain_mask 2
  }
#END_REPEAT

