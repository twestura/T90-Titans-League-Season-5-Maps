/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Placeholders */
#const PHON 1543
#const PHONL 1544
#const PHONN 1546
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

/* Placeholder Terrain Constants for Initial Generation */
#const T_BASE DLC_ROCK
#const T_PLAYER1 DIRT
#const T_PLAYER2 DIRT2

start_random
  percent_chance 50 #define TB
  percent_chance 50 #define LR
end_random

/* Land Position Constants */
if TB
  #const T1 rnd(75,105)
  #const T2 rnd(255,285)
elseif LR
  #const T1 rnd(165,195)
  #const T2 rnd(345,375)
endif

#const R 41
#const SMALLR 14
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const ROFFSET$i rnd(-1,1)
  #const R$i (R + ROFFSET$i)
  #const XOFF$i rnd(-1,1)
  #const YOFF$i rnd(-1,1)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)

  #const U$i (SMALLR - 2 * COS_T$i + 50)
  #const V$i (SMALLR - 2 * SIN_T$i + 50)
#END_FOR

#const T11 (T1 - 35)
#TRIG(T11)
#const A11 (SMALLR * COS_T11 + 50)
#const B11 (SMALLR * SIN_T11 + 50)

#const T12 (T1 + 35)
#TRIG(T12)
#const A12 (SMALLR * COS_T12 + 50)
#const B12 (SMALLR * SIN_T12 + 50)

#const T21 (T2 - 35)
#TRIG(T21)
#const A21 (SMALLR * COS_T21 + 50)
#const B21 (SMALLR * SIN_T21 + 50)

#const T22 (T2 + 35)
#TRIG(T22)
#const A22 (SMALLR * COS_T22 + 50)
#const B22 (SMALLR * SIN_T22 + 50)

/* Choses which Forest formation to use. */
#define FOREST_SPLIT
/* start_random
  percent_chance 50 #define FOREST_DIRECT
  percent_chance 50 #define FOREST_SPLIT
end_random */

/* Selects a theme. */
start_random
  percent_chance 40 #define AUTUMN
  percent_chance 40 #define SNOW_LIGHT
  percent_chance 20 #define SNOW_HEAVY
end_random

#const MUD 76

if AUTUMN
  #const TOP_TERRAIN GRASS3
  #const TOP_FOREST_MAIN DLC_FORESTAUTUMN
  #const TOP_FOREST_SECOND FOREST
  #const BOTTOM_TERRAIN DIRT3
  #const BOTTOM_FOREST PINE_FOREST
  #const SHORE BEACH
  #const TOP_MASK_1 LEAVES
  #const TOP_MASK_2 GRASS2
  #const TOP_MASK_3 DLC_DRYGRASS
  #const BOTTOM_MASK_1 DIRT
  #const BOTTOM_MASK_2 GRASS3
  #const WATER_MASK MED_WATER
  #const STRAGGLER_PLAYER PINETREE
  #const FOX RED_FOX
  #const ROCK_PLANT 1366 /* Plant, Flowers */
elseif SNOW_LIGHT
  #const TOP_TERRAIN DLC_DRYGRASS
  #const TOP_FOREST_MAIN DLC_FORESTAUTUMN
  #const TOP_FOREST_SECOND DLC_FORESTSNOWAUTUMN
  #const BOTTOM_TERRAIN DIRT
  #const BOTTOM_FOREST PINE_FOREST
  #const SHORE BEACH
  #const TOP_MASK_1 LEAVES
  #const TOP_MASK_2 MUD
  #const TOP_MASK_3 SNOW
  #const BOTTOM_MASK_1 GRASS3
  #const BOTTOM_MASK_2 SNOW
  #const WATER_MASK MED_WATER
  #const STRAGGLER_PLAYER PINETREE
  #const FOX RED_FOX
  #const ROCK_PLANT 1363 /* Plant, Shrub Dry */
elseif SNOW_HEAVY
  #const TOP_TERRAIN SNOW
  #const TOP_FOREST_MAIN SNOW_FOREST
  #const TOP_FOREST_SECOND DLC_FORESTSNOWAUTUMN
  #const BOTTOM_TERRAIN MUD
  #const BOTTOM_FOREST DLC_FORESTDEAD
  #const SHORE ICYSHORE
  #const TOP_MASK_1 GRASS3
  #const TOP_MASK_2 DIRT3
  #const TOP_MASK_3 LEAVES
  #const BOTTOM_MASK_1 SNOW
  #const BOTTOM_MASK_2 GRASS3
  #const WATER_MASK DEEP_WATER
  #const STRAGGLER_PLAYER DLC_DEADTREE
  #const FOX ARCTIC_FOX
  #const ROCK_PLANT 1365 /* Plant, Dead */
endif

start_random
  percent_chance 50 #const PLAYER_HUNT DEER
  percent_chance 50 #const PLAYER_HUNT DLC_IBEX
end_random

<PLAYER_SETUP>
direct_placement
ai_info_map_type ARABIA 0 0 0
behavior_version 2

/* Sets the "land" placeholder object to avoid rock terrain. */
effect_amount SET_ATTRIBUTE PHONL ATTR_TERRAIN_ID 4

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE HAWK ATTR_LINE_OF_SIGHT 0

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

<LAND_GENERATION>
base_terrain T_BASE
enable_waves 0

create_land {
  land_position 50 50
  terrain_type SNOW
  base_elevation 7
  number_of_tiles 0
  base_size 6
  zone 10
}

/* #FOR($i, 1, 3)
  create_land {
    assign_to AT_TEAM -10 0 0
    land_position X$i Y$i
    terrain_type T_PLAYER$i
