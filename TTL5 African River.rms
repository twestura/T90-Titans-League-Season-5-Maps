  number_of_clumps 8
  terrain_mask 1
}

create_terrain DIRT3 {
  base_terrain PLAYER_LAND
  land_percent 2
  number_of_clumps 4
  terrain_mask 1
}

#REPEAT(8)
  create_terrain BASE_TERRAIN {
    base_terrain PLAYER_LAND
    land_percent 100
    number_of_clumps 9320
    terrain_mask 1
  }
#END_REPEAT

create_terrain DLC_DIRT4 {
  base_terrain BASE_TERRAIN
  land_percent 4
  number_of_clumps 8
  terrain_mask 1
}

create_terrain DLC_CRACKED {
  base_terrain BASE_TERRAIN
  land_percent 2
  number_of_clumps 8
  terrain_mask 1
}

create_terrain DIRT3 {
  base_terrain BASE_TERRAIN
  land_percent 2
  number_of_clumps 4
  terrain_mask 1
}

<CONNECTION_GENERATION>
accumulate_connections

create_connect_all_lands {
  replace_terrain BASE_TERRAIN SHALLOW
  replace_terrain BEACH SHALLOW
  replace_terrain DLC_ACACIAFOREST DLC_WATER5

  terrain_cost BASE_TERRAIN 3
  terrain_cost PLAYER_LAND 0
  terrain_cost MIDDLE_TERRAIN 0
  terrain_cost PALM_DESERT 0
  terrain_cost DLC_NEWSHALLOW 0
  terrain_cost DLC_ACACIAFOREST 15
  terrain_cost SHALLOW 2
  terrain_cost DLC_WATER5 2
  
  terrain_size BEACH 0 0
  terrain_size BASE_TERRAIN 3 1
  terrain_size DLC_ACACIAFOREST 1 0
}

create_connect_all_players_land {
  replace_terrain BEACH SHALLOW
  terrain_size BEACH 15 0
}

<OBJECTS_GENERATION>
/* PLACEHOLDER OBJECTS */	
create_actor_area 60 60 100 58 /* for map edge PH */	

#FOR($i, 0, 20)
  create_actor_area (70 - $i) (50 + $i) boar_avoider 5
  create_actor_area (70 - $i) (50 + $i) gold_avoider 8
#END_FOR

/* Relic avoidance placeholders */
create_actor_area 0 0 left_corner 80
create_actor_area 119 119 right_corner 80

/* map edge placeholder */
create_object PLACEHOLDER_OBJECT_A {
  number_of_objects 9320
  temp_min_distance_group_placement 0
  avoid_actor_area 100
  actor_area 101
  actor_area_radius 1
}

/* to keep main mines from middle oasis */
