#HEADER_START
/*
 * African River for TTL 5.
 * Edited by T-West, December 2025.
 */

/*
	African River by Miaou (Discord: cebdos#8421)
	Created: 17-10-2021
	Version: 1.3
    Updated: 17-12-2021

    Map concept by Miaou

    Changelog
    1.0 Initial release
    1.1 Mines of a player now spawn when its TC is located in shallows
    1.2 Fixed a bug where villagers were not all spawning
    1.3 Changed zebra distribution and added ostrich

	Compatibility: Definitive Edition
*/
#HEADER_END

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* LANDS */
#const BASE_TERRAIN 41
#const MIDDLE_LAND 63
#const PLAYER_LAND 6
#const LAKE_LAND 4

#const MIDDLE_TERRAIN 9

/* TERRAINS */
#const TEMP_PLACEHOLDER_A 64
#const TEMP_PLACEHOLDER_B 65
#const TEMP_PLACEHOLDER_C 66
#const TEMP_PLACEHOLDER_D 67

/* OBJECTS */
#const PLACEHOLDER_OBJECT_A 346 /* for actor area */
#const PLACEHOLDER_OBJECT_B 1613 /* to force objects */
#const PLACEHOLDER_OBJECT_C 278 /* to force buildings */
#const PLACEHOLDER_OBJECT_D 647

#const REEDS 1350
#const PLANT_DRYGRASS 1359
#const PLANT_SHRUB 1362
#const PLANT_WEEDS 1364
#const PLANT_DEAD 1365

/* Player TC Locations */
#const T1 rnd(15,75)
#const T2 rnd(195,255)
#const R1 10
#const R2 8
#FOR($i,1,3)
  #TRIG(T$i)
  #const X$i (R$i * COS_T$i + 50)
  #const Y$i (R$i * SIN_T$i + 50)
#END_FOR


/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
if 2_PLAYER_GAME
  direct_placement
else
  random_placement
endif
ai_info_map_type SALT_MARSH 0 0 0
effect_amount SET_ATTRIBUTE DLC_OSTRICH ATTR_TERRAIN_ID 4

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
base_terrain BASE_TERRAIN

/* MIDDLE */
create_land {
  terrain_type MIDDLE_LAND
  land_position 50 50
  base_size 9
  number_of_tiles 0
  land_id 420
  set_circular_base
}
    
/* PLAYERS */
if 2_PLAYER_GAME
#FOR($i, 1, 3)
  create_land {
    land_position X$i Y$i
    terrain_type PLAYER_LAND
    base_size 0
    top_border 17
    right_border 17
    bottom_border 17
    left_border 17
    clumping_factor 15
    border_fuzziness 20
    assign_to AT_TEAM -10 0 0
  }
#END_FOR
else
  create_player_lands {
    terrain_type PLAYER_LAND
    base_size 0
    top_border 17
    right_border 17
    bottom_border 17
    left_border 17
    clumping_factor 15
    border_fuzziness 20
    circle_radius 10
  }
endif

/* LAKES */
create_land {
  terrain_type LAKE_LAND
  base_size 6
  land_percent 1
  clumping_factor 15
  min_placement_distance 38
  land_id 401
}

create_land {
  terrain_type LAKE_LAND
  base_size 6
  land_percent 1
  clumping_factor 16
  min_placement_distance 38
  land_id 402
}

create_land {
  terrain_type LAKE_LAND
  base_size 6
  land_percent 1
  clumping_factor 17
  min_placement_distance 38
  land_id 403
}

create_land {
  terrain_type LAKE_LAND
  base_size 6
  land_percent 1
  clumping_factor 18
  min_placement_distance 38
  land_id 404
}

<ELEVATION_GENERATION>
create_elevation 7 {
  base_terrain PLAYER_LAND
  number_of_tiles 400
  number_of_clumps 20
  enable_balanced_elevation
}

<TERRAIN_GENERATION>
/* TTL5: No color correction. */
/* color_correction CC_DESERT */

/* MIDDLE */
#REPEAT(8)
  create_terrain PLAYER_LAND {
    base_terrain MIDDLE_LAND
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain MIDDLE_TERRAIN {
    base_terrain LAKE_LAND
    land_percent 100
    number_of_clumps 9320
    terrain_mask 2
  }
#END_REPEAT

#REPEAT(8)
  create_terrain MIDDLE_TERRAIN {
    base_terrain PLAYER_LAND
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 17
  }
#END_REPEAT

#REPEAT(8)
  create_terrain LAKE_LAND {
    base_layer LAKE_LAND
    land_percent 100
    number_of_clumps 9320
  }
#END_REPEAT

/* for cosmetics */
create_terrain MIDDLE_TERRAIN {
  base_terrain MIDDLE_TERRAIN
  land_percent 6
  number_of_clumps 1
  clumping_factor -50
  spacing_to_other_terrain_types 1
  terrain_mask 1
}

#REPEAT(8)
  create_terrain TEMP_PLACEHOLDER_A {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 9320
    spacing_to_other_terrain_types 6
    height_limits 0 0
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DLC_NEWSHALLOW {
    base_terrain TEMP_PLACEHOLDER_A
    land_percent 100
    number_of_clumps 9320
    spacing_to_other_terrain_types 3
  }
#END_REPEAT

#REPEAT(8)
  create_terrain PALM_DESERT {
    base_terrain DLC_NEWSHALLOW
    land_percent 100
    number_of_clumps 9320
    spacing_to_other_terrain_types 1
    set_avoid_player_start_areas 8
  }
#END_REPEAT

create_terrain DLC_NEWSHALLOW {
  base_terrain TEMP_PLACEHOLDER_A
  number_of_tiles 12
  number_of_clumps 12
  height_limits 0 0
  set_flat_terrain_only
  spacing_to_other_terrain_types 1
  set_avoid_player_start_areas 7
}

/* cosmetics */
#REPEAT(8)
  create_terrain BASE_TERRAIN {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 9320
    terrain_mask 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain MIDDLE_TERRAIN {
    base_terrain TEMP_PLACEHOLDER_A
    land_percent 100
    number_of_clumps 9320
  }
#END_REPEAT

/* FOREST */
/* Player Forests */
create_terrain DLC_ACACIAFOREST {
  base_terrain PLAYER_LAND
  number_of_tiles 720
  number_of_clumps 8
  clumping_factor 40
  spacing_to_other_terrain_types 3
  set_avoid_player_start_areas 18
}

/* Neutral Forests */
create_terrain PINE_FOREST {
  base_terrain BASE_TERRAIN
  number_of_tiles 1080
  number_of_clumps 12
  clumping_factor 40
  spacing_to_other_terrain_types 6
  set_avoid_player_start_areas 42
}

#REPEAT(8)
  create_terrain DLC_ACACIAFOREST {
    base_terrain PINE_FOREST
    land_percent 100
    number_of_clumps 9320
  }
#END_REPEAT

/* COSMETICS */
/* Water Cosmetics */
create_terrain DLC_WATER5 {
  base_terrain LAKE_LAND
  land_percent 2
  number_of_clumps 12
  terrain_mask 2
}

#REPEAT(8)
  create_terrain LAKE_LAND {
    base_terrain LAKE_LAND
    land_percent 100
    number_of_clumps 9320
    terrain_mask 1
  }
#END_REPEAT

/* Middle Cosmetics */
#REPEAT(8)
  create_terrain GRASS {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 9320
    terrain_mask 1
  }
#END_REPEAT

create_terrain PALM_DESERT {
  base_layer GRASS
  number_of_tiles 60
  number_of_clumps 15
