<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type ARENA 0 0 0

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

/* Outlines behind rocks. */
effect_amount SET_ATTRIBUTE DLC_ROCKBEACH ATTR_OCCLUSION_MODE 2

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

<LAND_GENERATION>
base_terrain SHALLOW

/* Middle terrain. */
create_land {
  terrain_type BEACH
  land_position rnd(49,50) rnd(49,50)
  land_id 10
  number_of_tiles 0
  base_size 50
  set_circular_base
}

/* Player Lands */
#FOR($i, 1, 3)
  create_land {
    land_position X$i Y$i
    assign_to AT_TEAM -10 0 0
    number_of_tiles 0
    terrain_type BEACH
    land_id $i
  }
#END_FOR

/* Middle Lands */
#FOR($i, 1, 3)
  create_land {
    land_position MID_X$i MID_Y$i
    number_of_tiles 0
    terrain_type BEACH
    land_id 1$i
  }
#END_FOR

<TERRAIN_GENERATION>
/* Creates the ring of trees around the outside. */
#REPEAT(8)
  create_terrain PLAYER_CENTER_LAYER {
    base_terrain BEACH
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 3
  }
#END_REPEAT
#REPEAT(8)
  create_terrain PALM_DESERT {
    base_terrain PLAYER_CENTER_LAYER
    land_percent 100
    number_of_clumps 8192
    set_avoid_player_start_areas 22
  }
#END_REPEAT

#REPEAT(8)
  create_terrain PLAYER_CENTER_LAYER {
    base_terrain PALM_DESERT
    land_percent 100
    number_of_clumps 8192
    if TINY_MAP
      spacing_to_other_terrain_types 8
    elseif SMALL_MAP
      spacing_to_other_terrain_types 12
    elseif MEDIUM_MAP
      spacing_to_other_terrain_types 13
    elseif LARGE_MAP
      spacing_to_other_terrain_types 14
    elseif HUGE_MAP
      spacing_to_other_terrain_types 15
    elseif GIGANTIC_MAP
      spacing_to_other_terrain_types 16
    else
      spacing_to_other_terrain_types 17
    endif
  }
#END_REPEAT

/* Creates the water around the outside. */
#REPEAT(8)
  create_terrain DLC_WATER5 {
    base_terrain SHALLOW
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 6
  }
#END_REPEAT

/* Randomizes the edges of the shallows. */
create_terrain DLC_WATER5 {
  base_terrain SHALLOW
  land_percent 2
  number_of_clumps 10
  set_scale_by_groups
  spacing_to_other_terrain_types 4
}

/* Places Desert in the middle, keeping a masked region centered at players. */
#REPEAT(8)
  create_terrain DESERT {
    base_terrain PLAYER_CENTER_LAYER
    land_percent 100
    number_of_clumps 8192
    set_avoid_player_start_areas 10
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DESERT {
    base_terrain PLAYER_CENTER_LAYER
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
#END_REPEAT

/* Masks the Shallow terrain with Rajas Shallows. */
#REPEAT(8)
  create_terrain DLC_NEWSHALLOW {
    base_terrain SHALLOW
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
#END_REPEAT

/* Masks Desert underneath Beach. */
#REPEAT(8)
  create_terrain DESERT {
    base_terrain BEACH
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
#END_REPEAT

/* Middle Forests */
create_terrain DLC_RAINFOREST {
  base_terrain DESERT
  if TINY_MAP
    number_of_tiles 30
    number_of_clumps 3
  else
    land_percent 2
    number_of_clumps 12
    set_scale_by_groups
  endif
  spacing_to_other_terrain_types 4
  set_avoid_player_start_areas 28
}

#REPEAT(8)
  create_terrain PALM_DESERT {
    base_terrain DLC_RAINFOREST
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Forest Masking */
create_terrain DLC_RAINFOREST {
  base_terrain PALM_DESERT
  land_percent 8
  number_of_clumps 100
  set_scale_by_groups
  terrain_mask 2
}

#REPEAT(8)
  create_terrain DLC_RAINFOREST {
    base_terrain PALM_DESERT
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/* Terrain Masking */
create_terrain GRASS {
  base_terrain DESERT
  land_percent 5
  number_of_clumps 12
  set_scale_by_groups
  terrain_mask 1
}

/* Water Masking */
#REPEAT(8)
  create_terrain WATER {
    base_terrain DLC_WATER5
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 3
  }
#END_REPEAT

#REPEAT(8)
  create_terrain MED_WATER {
    base_terrain WATER
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 3
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DEEP_WATER {
    base_terrain MED_WATER
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 3
  }
#END_REPEAT

create_terrain DLC_WATER5 {
  base_terrain WATER
  land_percent 100
  number_of_clumps 10000
  set_scale_by_groups
  terrain_mask 2
}

create_terrain DLC_WATER5 {
  base_terrain MED_WATER
  land_percent 100
  number_of_clumps 10000
  set_scale_by_groups
  terrain_mask 2
}

<OBJECTS_GENERATION>

/* Create Actor Areas */
#FOR($i, 1, 3)
  create_actor_area U$i V$i center$i 0

  /* Placement tiles for Gates */
  create_actor_area (U$i - 20) (V$i) gate_position$i 0
  create_actor_area (U$i - 20) (V$i) gate_position_down$i 0
  create_actor_area (U$i + 20) (V$i) gate_position$i 0
  create_actor_area (U$i + 20) (V$i) gate_position_down$i 0
  create_actor_area (U$i) (V$i - 20) gate_position$i 0
  create_actor_area (U$i) (V$i - 20) gate_position_up$i 0
  create_actor_area (U$i) (V$i + 20) gate_position$i 0
  create_actor_area (U$i) (V$i + 20) gate_position_up$i 0

  create_actor_area (U$i - 14) (V$i - 14) gate_position$i 0
  create_actor_area (U$i - 14) (V$i - 14) gate_position_vert$i 0
  create_actor_area (U$i - 14) (V$i + 15) gate_position$i 0
  create_actor_area (U$i - 14) (V$i + 15) gate_position_hori$i 0
  create_actor_area (U$i + 15) (V$i - 14) gate_position$i 0
  create_actor_area (U$i + 15) (V$i - 14) gate_position_hori$i 0
  create_actor_area (U$i + 15) (V$i + 15) gate_position$i 0
  create_actor_area (U$i + 15) (V$i + 15) gate_position_vert$i 0

  /* Exact tiles for each Gate for walls to avoid. */
  /* Bottom-left and Top-right */
  create_actor_area (U$i - 20) (V$i - 2) gate_tile 0
  create_actor_area (U$i - 20) (V$i - 1) gate_tile 0
  create_actor_area (U$i - 20) (V$i) gate_tile 0
  create_actor_area (U$i - 20) (V$i + 1) gate_tile 0
  create_actor_area (U$i + 20) (V$i - 2) gate_tile 0
  create_actor_area (U$i + 20) (V$i - 1) gate_tile 0
  create_actor_area (U$i + 20) (V$i) gate_tile 0
  create_actor_area (U$i + 20) (V$i + 1) gate_tile 0

  /* Top-left and Bottom-right */
  create_actor_area (U$i - 2) (V$i - 20) gate_tile 0
  create_actor_area (U$i - 1) (V$i - 20) gate_tile 0
  create_actor_area (U$i) (V$i - 20) gate_tile 0
  create_actor_area (U$i + 1) (V$i - 20) gate_tile 0
  create_actor_area (U$i - 2) (V$i + 20) gate_tile 0
  create_actor_area (U$i - 1) (V$i + 20) gate_tile 0
  create_actor_area (U$i) (V$i + 20) gate_tile 0
  create_actor_area (U$i + 1) (V$i + 20) gate_tile 0

  /* Left and Right Diagonal Gates */
  create_actor_area (U$i - 12) (V$i - 17) gate_tile 0
  create_actor_area (U$i - 13) (V$i - 16) gate_tile 0
  create_actor_area (U$i - 14) (V$i - 15) gate_tile 0
  create_actor_area (U$i - 15) (V$i - 14) gate_tile 0
  create_actor_area (U$i - 16) (V$i - 13) gate_tile 0
  create_actor_area (U$i - 17) (V$i - 12) gate_tile 0

  create_actor_area (U$i + 17) (V$i + 12) gate_tile 0
  create_actor_area (U$i + 16) (V$i + 13) gate_tile 0
  create_actor_area (U$i + 15) (V$i + 14) gate_tile 0
  create_actor_area (U$i + 14) (V$i + 15) gate_tile 0
  create_actor_area (U$i + 13) (V$i + 16) gate_tile 0
  create_actor_area (U$i + 12) (V$i + 17) gate_tile 0

  /* Top and Bottom Diagonal Gates */
  create_actor_area (U$i - 17) (V$i + 12) gate_tile 0
  create_actor_area (U$i - 16) (V$i + 13) gate_tile 0
  create_actor_area (U$i - 15) (V$i + 14) gate_tile 0
  create_actor_area (U$i - 14) (V$i + 15) gate_tile 0
  create_actor_area (U$i - 13) (V$i + 16) gate_tile 0
  create_actor_area (U$i - 12) (V$i + 17) gate_tile 0

  create_actor_area (U$i + 12) (V$i - 17) gate_tile 0
  create_actor_area (U$i + 13) (V$i - 16) gate_tile 0
  create_actor_area (U$i + 14) (V$i - 15) gate_tile 0
  create_actor_area (U$i + 15) (V$i - 14) gate_tile 0
  create_actor_area (U$i + 16) (V$i - 13) gate_tile 0
  create_actor_area (U$i + 17) (V$i - 12) gate_tile 0

  /* Positions for Walls to avoid to stay flat on the sides. */
  create_actor_area (U$i - 21) (V$i) wall_side_avoider 0
  create_actor_area (U$i + 21) (V$i) wall_side_avoider 0
  create_actor_area (U$i) (V$i - 21) wall_side_avoider 0
  create_actor_area (U$i) (V$i + 21) wall_side_avoider 0
#END_FOR

