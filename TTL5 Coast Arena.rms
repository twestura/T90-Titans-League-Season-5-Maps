/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Comment Start and End Tokens (not removed by the preprocess) */
#const [ 69
#const ] 70

/* Placeholders */
#const PHON 1543
#const PHONL 1544
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

/* Terrains */
#const PLAYER_CENTER_LAYER DLC_DESERTGRAVEL
#const UNDERBRUSH_JUNGLE 77
#const RAINFOREST_GRASS 83

/* Objects */
#const GATE_UP 64
#const GATE_DOWN 88
#const GATE_HORI 659
#const GATE_VERT 667
#const SEA_WALL 788
#const TREE_REEDS 1350

#const PLANT_JUNGLE 1351
#const PLANT_UNDERBRUSH_TROPICAL 1352
#const PLANT_UNDERBRUSH 1353
#const PLANT_RAINFOREST 1354
#const PLANT_UNDERBRUSH_RAINFOREST 1355

/* Player Start Areas */
#const T1 rnd(0,359)
#const ANGLE rnd(135,225)
#const T2 (T1 + ANGLE % 360)
#const R 27
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)
#END_FOR

#const SMALL_R 25
#const MID_T1 (T1 + T2 / 2)
#const MID_T2 (MID_T1 + 180 % 360)
#FOR($i, 1, 3)
  #TRIG(MID_T$i)
  #const MID_X$i (SMALL_R * COS_MID_T$i + 50)
  #const MID_Y$i (SMALL_R * SIN_MID_T$i + 50)
#END_FOR

