  create_terrain DESERT {
    base_terrain SLOPE_PEAK
    number_of_tiles 4
    spacing_to_other_terrain_types 3
    spacing_to_specific_terrain ROAD
    spacing_to_specific_terrain DIRT 16
    clumping_factor 100
  }

  create_terrain DIRT {
    base_terrain DESERT
