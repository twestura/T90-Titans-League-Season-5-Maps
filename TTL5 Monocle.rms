    base_terrain SLOPE_PEAK
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain BASE_TERRAIN 7
    spacing_to_specific_terrain MIDDLE_TERRAIN 6
  }
#END_REPEAT

/* Placeholders for regular spaces between ponds.. */
