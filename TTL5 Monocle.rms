/* Relics */
#FOR($i, 0, 5)
  create_object PHRELIC {
    avoid_actor_area relic_success
    number_of_objects 4
    terrain_to_place_on BASE_TERRAIN
    min_distance_to_players RELIC_PLAYER_SPACING
    set_circular_placement
    max_distance_to_other_zones RELIC_ZONE_SPACING
    avoid_forest_zone 1
    min_distance_to_map_edge 1
    temp_min_distance_group_placement RELIC_SPACING

    actor_area relic_spot_$i
    actor_area_radius 0
  }

  create_object PHRELIC {
    avoid_actor_area relic_success
    number_of_objects 32
    actor_area_to_place_in relic_spot_$i
    actor_area relic_spacing_$i
    actor_area_radius RELIC_SPACING
  }

  create_object PHRELIC {
    avoid_actor_area relic_success
    terrain_to_place_on BASE_TERRAIN
    min_distance_to_players RELIC_PLAYER_SPACING
    set_circular_placement
    max_distance_to_other_zones RELIC_ZONE_SPACING
    avoid_forest_zone 1
    min_distance_to_map_edge 1
    avoid_actor_area relic_spacing_$i

    actor_area relic_end_$i
    actor_area_radius 0
  }

  create_object PHRELIC {
    avoid_actor_area relic_success
    actor_area_to_place_in relic_end_$i
    actor_area relic_success_$i
    actor_area_radius 120
  }

  create_object PHRELIC {
    avoid_actor_area relic_success
    avoid_actor_area relic_success_$i
    actor_area relic_failure_$i
    actor_area_radius 120
  }

  create_object RELIC {
    avoid_actor_area relic_success
    number_of_objects 16
    min_distance_group_placement 2
    avoid_actor_area relic_failure_$i
    actor_area_to_place_in relic_spot_$i
  }
  
  create_object RELIC {
    avoid_actor_area relic_success
    min_distance_group_placement 2
    avoid_actor_area relic_failure_$i
    actor_area_to_place_in relic_end_$i
  }

  create_object PHRELIC {
    avoid_actor_area relic_success
    avoid_actor_area relic_failure_$i
    actor_area relic_success
    actor_area_radius 120
  }
#END_FOR

