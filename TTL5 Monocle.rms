#HEADER_START
/*
 * Monocle for TTL 5.
 * Edited by T-West, December 2025.
 * Based on the map by Chrazini.
 * Only supports 1v1s on the tiny map size and Random Map game mode.
 *
 * Changes from the previous version:
 * - Ponds are always 1 tile.
 * - Pond terrains alternate medium and deep water.
 * - Ponds alternatve Box Turtles and Shore Fish.
 * - Connection generation ensures there is always a small path between the
 *   players in the middle.
 * - Outside Relics are more balanced.
 * - Outside resources have a larger group placement radius.
 * - Player resources have more randomness in their spawn locations.
 */

/*
	Monocle by Chrazini
	Created: 21-02-2020
	Version: 1.3
	BSV: 7.0.3
	Compatibility: Definitive Edition

	Theme: American
	Style: Land
	Formation: Circle

	Please report bugs or requests on either:
	Steam: https://steamcommunity.com/id/chrazini
	Discord: Chrazini#5687
	AoEZone: https://www.aoezone.net/members/chrazini.48855/
	Voobly: https://www.voobly.com/profile/view/123721778

	Changelog 21-02-2020 | Version 1.0
	� Initial release.

	Changelog 03-04-2020 | Version 1.1
	� Fixed a bug that would sometimes cause the starting sheep to not generate correctly.

	Changelog 09-12-2020 | Version 1.2
	� Extra resources are now more equally distributed.
	� Gold deposits will now generate further apart from other gold deposits.
	� Stone deposits will now generate further apart from other stone deposits.
	� Boars have been moved closer to the town centre.
	� Added support for multiple game modes to be enabled at the same time.
	� Changed the villager distribution in Empire Wars.
	� Buildings are more distributed more adequately during Empire Wars.
	� Playing on "Low Resources" will now activate mode-toggle.
	� The radius of the middle has decreased.
	� Forest in the middle has been decreased when playing Empire Wars.
	� Shore fish should now be more evenly spread out.

	Changelog 10-12-2020 | Version 1.3
	� Added better compatibility for Regicide and Capture the Relic.
	� Added minor aesthetic changes.
*/
#HEADER_END

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Placeholders */
#const PHRELIC 1291 /* Invisible object for positioning Relics. */
#const PHON 1543
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

/* Scenery */
#const ROCK_2 1323 /* Rock 2 */

/* Terrains */
#const SPAWN_TERRAIN 76

#const BASE_FOREST 17
#const BASE_TERRAIN 12
#const BASE_BLEND_A 5
#const BASE_BLEND_B 3
#const BASE_BLEND_C 100

#const SLOPE_PEAK 70
#const SLOPE_TERRAIN 40
#const SLOPE_BLEND_A 76
#const SLOPE_BLEND_B 5

#const MIDDLE_FOREST 56
#const MIDDLE_TERRAIN 76
#const MIDDLE_BLEND_A 5
#const MIDDLE_BLEND_B 9
#const MIDDLE_BLEND_C 77

#const WATER_2D_SHORELESS 15

/* Player Land Locations */
#const T1 rnd(0,359)
#const ANGLE rnd(135,225)
#const T2 (T1 + ANGLE)
#const R 18
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)
#END_FOR

/* Relic Attributes */
#const RELIC_SPACING 50
#const RELIC_PLAYER_SPACING 35
#const RELIC_ZONE_SPACING 8

/* Spacing Distances for Inner Gold Mines */
#const GOLD_PLAYER_DIST 20
#const GOLD_SEPARATION 8
#const GOLD_ROCK_DISTANCE 7

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type ARABIA 0 0 0

/* Draws object outlines behind the rocks. */
effect_amount SET_ATTRIBUTE ROCK ATTR_OCCLUSION_MODE 2
effect_amount SET_ATTRIBUTE ROCK_2 ATTR_OCCLUSION_MODE 2

/* Makes the rocks 2x2 size. */
effect_amount SET_ATTRIBUTE ROCK ATTR_RADIUS_1 1
effect_amount SET_ATTRIBUTE ROCK ATTR_RADIUS_2 1

/* Sets Bird line of sight to 0. */
effect_amount SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

/* Placeholder object for Relics */
effect_amount SET_ATTRIBUTE PHRELIC ATTR_DEAD_ID -1
effect_amount SET_ATTRIBUTE PHRELIC ATTR_TERRAIN_ID 4
effect_amount SET_ATTRIBUTE PHRELIC ATTR_LINE_OF_SIGHT 0
effect_amount SET_ATTRIBUTE PHRELIC ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE PHRELIC ATTR_STORAGE_VALUE 0

/*
 * Uses universities to fill gaps with rocks.
 * Needs to use a dead object instead of a second object due to
 * pathfinding-related bugs introduced in the summer 2025 patch.
 * The second object technique results in an "unable to build" adjacent to the
 * rock.
 */
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_DEAD_ID ROCK
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_HITPOINTS 0
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_DYING_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_STANDING_GRAPHIC 3358
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_STANDING2_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_DESTRUCTION_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_DESTRUCTION_RUBBLE_GRAPHIC 0
effect_amount GAIA_SET_ATTRIBUTE UNIVERSITY ATTR_DYING_SOUND -1

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

<LAND_GENERATION>
base_terrain BASE_TERRAIN
enable_waves 0

/* Creates player lands. */
#FOR($i, 1, 3)
  create_land {
    land_position X$i Y$i
    terrain_type SPAWN_TERRAIN
    assign_to AT_TEAM -10 0 0
  }
#END_FOR

/* Sets up the ring of hills. */
create_land { terrain_type SLOPE_PEAK number_of_tiles 45 base_size 3 base_elevation 4 clumping_factor 15 zone 8 land_id 500 land_position 84 50 } 
create_land { terrain_type SLOPE_PEAK number_of_tiles 45 base_size 3 base_elevation 4 clumping_factor 15 zone 8 land_id 500 land_position 84 52 } 
