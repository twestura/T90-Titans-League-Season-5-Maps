/* Paints the elevated ring. */

/* Ensures the `SLOPE_PEAK` terrain covers all of the top. */
#REPEAT(12)
  create_terrain SLOPE_PEAK {
    base_terrain BASE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    set_scale_by_groups
    height_limits 4 4
  }
#END_REPEAT

#REPEAT(12)
  create_terrain SLOPE_PEAK {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    set_scale_by_groups
    height_limits 4 4
  }
#END_REPEAT

/* Rock around the top of the ring. */
#REPEAT(8)
  create_terrain SLOPE_TERRAIN {
    base_terrain BASE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    height_limits 2 3
  }
  
  create_terrain SLOPE_TERRAIN {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    height_limits 2 3
  }
#END_REPEAT

/* Masking on the top of the rock. */
#REPEAT(8)
  create_terrain SLOPE_PEAK {
    base_terrain SLOPE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    height_limits 3 3
    terrain_mask 1
  }
#END_REPEAT

/* Rock masked towards the bottom of the slope. */
#REPEAT(8)
  create_terrain SLOPE_TERRAIN {
    base_terrain MIDDLE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    height_limits 1 1
    terrain_mask 2
  }

  create_terrain SLOPE_TERRAIN {
    base_terrain BASE_TERRAIN
    land_percent 100
    number_of_clumps 8192
    height_limits 1 1
    terrain_mask 2
  }
#END_REPEAT

