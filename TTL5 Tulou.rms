/*
 * Circular Walls
 * Uses a technique involving terrain blocking placeholders to allow for the
 * players to control the walls at the start of the game. This technique avoids
 * requiring the player to capture Gaia walls, thereby allowing civilization-
 * specific bonuses to apply to the walls, such as Byzantine HP.
 */
create_object TERRAIN_BLOCKER {
  number_of_objects 64
  set_place_for_every_player
  set_gaia_object_only
  set_circular_placement
  min_distance_to_players 11
  max_distance_to_players 12
  find_closest
  actor_area inner_wall_0
  actor_area_radius 0
}

create_object TERRAIN_BLOCKER {
  number_of_objects 14400
  set_place_for_every_player
  set_gaia_object_only
  set_circular_placement
  min_distance_to_players 13
  max_distance_to_players 14
  actor_area outer_wall_0
  actor_area_radius 0
}

