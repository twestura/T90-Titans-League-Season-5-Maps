  number_of_objects 3
}

create_object RED_CROWN_CRANE {
  number_of_objects 3
}

/* Avoiders for player Gold Mines. */
create_object PHON {
  set_place_for_every_player
  number_of_objects 4
  find_closest
  min_distance_to_players 11
  max_distance_to_players 11
  actor_area gold_avoider
  actor_area_radius 1
}

/*
 * Actor Areas for positioning Gates.
 * By using find_closest and actor areas, we're able to isloate the four tiles
 * that are used for each Gate. The placeholders (not terrain blockers) used
 * to place walls as a second object avoid these tiles.
 */
create_object PHON {
  set_place_for_every_player
  set_gaia_object_only
  number_of_objects 2
  find_closest
  min_distance_to_players 12
  max_distance_to_players 12
  actor_area right_midpoints
  actor_area_radius 0
}

create_object PHON {
  set_place_for_every_player
  set_gaia_object_only
  number_of_objects 2
  find_closest
  min_distance_to_players 12
  max_distance_to_players 12
  avoid_actor_area right_midpoints
  actor_area left_midpoints
  actor_area_radius 0
}

