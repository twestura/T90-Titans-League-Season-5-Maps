<ELEVATION_GENERATION>
/* Outer elevation. */
#REPEAT(8)
  create_elevation 4 {
    base_terrain LEAVES
    number_of_tiles 14400
    spacing 5
    enable_balanced_elevation
    number_of_clumps 14400
  }
#END_REPEAT

/* Inner elevation. */
create_elevation 1 {
  base_terrain GRASS
  number_of_tiles 1400
  spacing 1
  enable_balanced_elevation
  number_of_clumps 50
}

<TERRAIN_GENERATION>
/* Outside terrain and woodlines. */
#REPEAT(8)
  create_terrain BAMBOO {
    base_terrain LEAVES
    land_percent 100
    number_of_clumps 8196
    height_limits 3 6
  }

  create_terrain JUNGLE {
    base_terrain LEAVES
    land_percent 100
    number_of_clumps 8196
    height_limits 0 0
  }
#END_REPEAT

#REPEAT(8)
  create_terrain FARM_RICE {
    base_terrain LEAVES
    land_percent 100
    number_of_clumps 8196
    terrain_mask 1
    height_limits 0 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain FARM_TERRAIM {
    base_terrain LEAVES
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/* Outside patches. */
create_terrain BROWNWATER {
  base_terrain LEAVES
  number_of_tiles 1000
  number_of_clumps 25
}

create_terrain MUD {
  base_terrain LEAVES
  number_of_tiles 1000
  number_of_clumps 25
}

create_terrain MUDDY_SHALLOW {
  base_terrain LEAVES
  number_of_tiles 1000
  number_of_clumps 25
}

#REPEAT(8)
  create_terrain FARM_TERRAIM {
    base_terrain BROWNWATER
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
  create_terrain FARM_TERRAIM {
    base_terrain MUD
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
  create_terrain FARM_TERRAIM {
    base_terrain MUDDY_SHALLOW
    land_percent 100
    number_of_clumps 8192
    terrain_mask 2
  }
#END_REPEAT

/* Inside Forests */
create_terrain DLC_RAINFOREST {
  base_terrain GRASS
  number_of_tiles 750
  number_of_clumps 35
  set_avoid_player_start_areas 22
  spacing_to_other_terrain_types 5
}

/* Changes the leaves under the forests. */
#REPEAT(8)
  create_terrain LEAVES {
    base_terrain DLC_RAINFOREST
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/*
 * Replaces the Snow placeholder with grass.
 * Perform the replacement after forest generation to avoid the Relic spawns
 * becoming occupied by trees.
 */
#REPEAT(8)
  create_terrain GRASS {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/*
 * Replaces the Grass with Jungle Road.
 * Also adjusts the terrain in the middle while adding beaches.
 */
#REPEAT(8)
  create_terrain DLC_JUNGLEROAD {
    base_terrain GRASS
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
    beach_terrain DLC_BEACH2
  }
  create_terrain DIRT {
    base_terrain DLC_SAVANNAH
    land_percent 100
    number_of_clumps 8192
    beach_terrain DLC_BEACH2
  }
#END_REPEAT

<OBJECTS_GENERATION>
/* Actor areas for the outside resources. */
