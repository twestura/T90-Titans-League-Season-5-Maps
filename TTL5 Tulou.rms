#HEADER_START
/*
 * Tulou for TTL 5.
 * Edited by T-West, December 2025.
 * Based on the map Tulou by Marintho, as seen in Stonghold Frenzy II.
 */
#HEADER_END

/*
 * Defeat players if the game mode is not set to Regicide.
 * Includes a check for the secondary game mode checkboxes.
 * Note the game mode must be Regicide, the checkbox cannot simply be
 * selected for another game mode.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif DEATH_MATCH
  #define ADMIN_RESTART
elseif CAPTURE_THE_RELIC
  #define ADMIN_RESTART
elseif RANDOM_MAP
  #define ADMIN_RESTART
elseif TURBO_RANDOM_MAP
  #define ADMIN_RESTART
elseif KING_OT_HILL
  #define ADMIN_RESTART
elseif WONDER_RACE
  #define ADMIN_RESTART
elseif DEFEND_WONDER
  #define ADMIN_RESTART
elseif EMPIRE_WARS
  #define ADMIN_RESTART
elseif BATTLE_ROYALE
  #define ADMIN_RESTART
elseif SUDDEN_DEATH
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Placeholders */
#const PHON 1543
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

/* Terrains */
#const FARM_TERRAIM 7
#const FARM_RICE 63
#const MUD 76
#const UNDERBRUSH_JUNGLE 76
#const GREENWATER 95
#const BROWNWATER 96

/* Objects */
#const GATE_UP 64
#const GATE_DOWN 88
#const PAGODA_A 1201
#const PAGODA_B 1202
#const PAGODA_C 1203
#const STATUE_CIVILIZATION 1279
#const QUEEN 1292 /* Western */
#const RED_CROWN_CRANE 2026

/* Player Land Locations */
#const T1 rnd(0,359)
#const ANGLE rnd(135,225)
#const T2 (T1 + ANGLE)
#const R 26
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)
#END_FOR

/* 50/50 chance of Kings or Queens. */
start_random
  percent_chance 50 #define USE_QUEENS
end_random

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type ARENA 0 0 0

/* Allow Forage and Stone to spawn freely on the outside terrain. */
effect_amount SET_ATTRIBUTE FORAGE ATTR_TERRAIN_ID 0
effect_amount SET_ATTRIBUTE STONE ATTR_TERRAIN_ID 0

/* Set the border forests to have 200 wood (instead of the default 100 wood). */
effect_amount SET_ATTRIBUTE JUNGLETREE ATTR_STORAGE_VALUE 200 

/* Sets Bird line of sight to 0. */
effect_amount SET_ATTRIBUTE HAWK ATTR_LINE_OF_SIGHT 0
effect_amount SET_ATTRIBUTE RED_CROWN_CRANE ATTR_LINE_OF_SIGHT 0

if USE_QUEENS
  effect_amount SET_ATTRIBUTE QUEEN ATTR_MOVE_SPEED 1.32
  effect_amount UPGRADE_UNIT KING QUEEN 0
endif

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

<LAND_GENERATION>
base_terrain LEAVES

#FOR($i, 1, 3)
  create_land {
    land_position X$i Y$i
    assign_to AT_TEAM -10 0 0
    terrain_type GRASS
    top_border 11
    bottom_border 12
    right_border 12
    left_border 11
    border_fuzziness 100
  }
#END_FOR

