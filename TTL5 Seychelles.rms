	min_distance_to_players 17
	find_closest
	enable_tile_shuffling
	set_circular_placement
	avoid_forest_zone 4
	temp_min_distance_group_placement 12
	terrain_to_place_on DLC_JUNGLEGRASS
  second_object DLC_RAINTREE
  actor_area 20
  actor_area_radius 1
}

