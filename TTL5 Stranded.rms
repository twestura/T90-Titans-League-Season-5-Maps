/* Middle Grass */
L {
  terrain_type RAINFOREST_GRASS
  land_position 50 50
  land_id 1000
}

/* Player Lands */
#FOR($i, 1, 3)
  L {
    land_position X$i Y$i
    terrain_type DESERT
    assign_to AT_TEAM -10 0 0
    number_of_tiles 0
    base_size 0
  }
#END_FOR

/* Middle Hills */
if HILLS_2
  #FOR($i, 1, 3)
    L {
      land_position A$i B$i
      terrain_type RAINFOREST_GRASS
      base_size rnd(3,4)
      number_of_tiles rnd(150,175)
      base_elevation 4
    }
  #END_FOR
elseif HILLS_3
  #FOR($i, 1, 4)
    L {
      land_position A$i B$i
      terrain_type RAINFOREST_GRASS
      base_size 3
      number_of_tiles rnd(115,135)
      base_elevation 4
    }
  #END_FOR
elseif HILLS_4
  #FOR($i, 1, 5)
    L {
      land_position A$i B$i
      terrain_type RAINFOREST_GRASS
      base_size 3
      number_of_tiles rnd(75,90)
      base_elevation 3
    }
  #END_FOR
endif

/* Player Forest and Gold Lands */
#FOR($i, 1, 3)
  L {
    land_position U$i V$i
    terrain_type FOREST
    base_size 2
    number_of_tiles 50
    clumping_factor 25
  }
#END_FOR

/* Relic Lands */
#FOR($i, 1, 3)
  L {
    land_position RELIC_X$i RELIC_Y$i
    base_size 0
    number_of_tiles 1
    terrain_type GRASS2
    land_id 3$i
  }
#END_FOR

<ELEVATION_GENERATION>
create_elevation 3 {
  enable_balanced_elevation
  base_terrain RAINFOREST_GRASS
  number_of_tiles 250
  number_of_clumps 10
}

<TERRAIN_GENERATION>
/* Covers water at the tops of hils. */
#REPEAT(8)
  create_terrain RAINFOREST_GRASS {
    base_terrain WATER
    land_percent 100
    number_of_clumps 8192
    height_limits 1 7
  }
#END_REPEAT

/* Covers "holes" in the middle terrain generation. */
#REPEAT(8)
