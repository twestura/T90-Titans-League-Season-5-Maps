#HEADER_START
/*
 * Stranded for TTL 5.
 * Edited by T-West, December 2025.
 *
 * This map is based on a map by Chrazini. I first played the map years ago in
 * the Improvement Cup, and we brought it back with some changes for
 * Wandering Warriors Cup II and for The Cartographers II. The map since has
 * become a standard map in the Definitive Edition, albeit with significant
 * changes, including starting the players on an outer island with a
 * Transport Ship.
 *
 * This verion continues the start we used in Wandering Warriors Cup II, with
 * no outer islands and with players starting with a Fishing Ship. I've
 * rewritten the script to advantage the arithmetical expressions that were
 * added to the Definitive Edition in April 2025, in particular using
 * trigonometry to balance player starting positions, woodlines, hills, and
 * Relics.
 */

/* Comments from the Improvement Cup version of the map follow. */
/*

	Stranded by Chrazini
	Created: 15-10-2020
	Version: 1.1
	BSV: 7.0.0
	Compatibility: Definitive Edition

	Theme: Tropical
	Style: Land & Water
	Formation: Circle

	Please report bugs or requests on either:
	Steam: https://steamcommunity.com/id/chrazini
	Discord: Chrazini#5687
	AoEZone: https://www.aoezone.net/members/chrazini.48855/
	Voobly: https://www.voobly.com/profile/view/123721778

	Changelog 15-10-2020 | Version 1.0
	� Initial release.

	Changelog 10-12-2020 | Version 1.1
	� Added better compatibility for Regicide and Capture the Relic.
	� Added minor aesthetic changes.

*/
#HEADER_END

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

/* Terrains */
#const UNDERBRUSH_JUNGLE 77
#const RAINFOREST_GRASS 83

/* Placeholders */
#const PHON 1543
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

/* Scenery Objects */
#const BONFIRE 304
#const PLANT_RAINFOREST 1354 /* Plant (Rainforest) */

/* Hack for create_land */
#const L 32

/* Player Land Locations */
#const T1 rnd(0,359)
#const ANGLE rnd(135,225)
#const T2 (T1 + ANGLE)
#const R 39
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)
#END_FOR

/* Lands for Relics, roughly halfway between players. */
#const RELIC_OFFSET_1 rnd(-20,20)
#const RELIC_OFFSET_2 rnd(-20,20)
#const RELIC_ANGLE_START (ANGLE / 2 + T1)
#const RELIC_ANGLE_1 (RELIC_ANGLE_START + RELIC_OFFSET_1)
#const RELIC_ANGLE_2 (RELIC_ANGLE_START + 180 + RELCI_OFFSET_2)
#const RELIC_R (R - 5)
#const RELIC_R_1 rnd(-2,2)
#const RELIC_R_2 rnd(-2,2)
#FOR($i, 1, 3)
  #TRIG(RELIC_ANGLE_$i)
  #const RELIC_X$i (RELIC_R + RELIC_R_1 * COS_RELIC_ANGLE_$i + 50)
  #const RELIC_Y$i (RELIC_R + RELIC_R_2 * SIN_RELIC_ANGLE_$i + 50)
#END_FOR

/* Randomizes the number of hills in the middle. */
start_random
  percent_chance 33 #define HILLS_2
  percent_chance 33 #define HILLS_3
  percent_chance 34 #define HILLS_4
end_random

#const HILL_THETA rnd(0,359)
#TRIG(HILL_THETA)

#const HILL_R 9
if HILLS_2
  #const A1 (HILL_R * COS_HILL_THETA + 50)
  #const B1 (HILL_R * SIN_HILL_THETA + 50)
  #const A2 (HILL_R * -1 * COS_HILL_THETA + 50)
  #const B2 (HILL_R * -1 * SIN_HILL_THETA + 50)
  #const A3 0
  #const A3 0
  #const B4 0
  #const B4 0
elseif HILLS_3
  #const HILL3_RNG rnd(0,1)
  #const HILL3_FLIP (HILL3_RNG * 180)
  #const HILLT1 (T1 - 30 + HILL3_FLIP)
  #const HILLT2 (T2 + 30 + HILL3_FLIP)
  #const HILLT3 (T1 + T2 / 2 + HILL3_FLIP)
  #FOR($i, 1, 4)
    #TRIG(HILLT$i)
    #const A$i (HILL_R + 2 * COS_HILLT$i + 50)
    #const B$i (HILL_R + 2 * SIN_HILLT$i + 50)
  #END_FOR
  #const B4 0
  #const B4 0
elseif HILLS_4
  #const A1 (HILL_R + 1 * COS_HILL_THETA + 50)
  #const B1 (HILL_R + 1 * SIN_HILL_THETA + 50)
  #const A2 (HILL_R + 1 * -1 * SIN_HILL_THETA + 50)
  #const B2 (HILL_R + 1 * COS_HILL_THETA + 50)
  #const A3 (HILL_R + 1 * -1 * COS_HILL_THETA + 50)
  #const B3 (HILL_R + 1 * -1 * SIN_HILL_THETA + 50)
  #const A4 (HILL_R + 1 * SIN_HILL_THETA + 50)
  #const B4 (HILL_R + 1 * -1 * COS_HILL_THETA + 50)
endif

/* Generates coordinates for forests next to each player. */
#const FOREST_R 20
#FOR($i, 1, 3)
  #const U$i (FOREST_R * COS_T$i + 50)
  #const V$i (FOREST_R * SIN_T$i + 50)
#END_FOR

/* Random number of Rugs. */
#const NUM_RUMS rnd(2,4)


/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
direct_placement
behavior_version 2
ai_info_map_type NOMAD 1 0 0
nomad_resources

/* Outlines behind water rock formations. */
effect_amount SET_ATTRIBUTE DLC_ROCKBEACH ATTR_OCCLUSION_MODE 2

/* Bird LoS to 0 */
effect_amount GAIA_SET_ATTRIBUTE MACAW ATTR_LINE_OF_SIGHT 0

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
base_terrain WATER
enable_waves 1

/* Desert Ring */
