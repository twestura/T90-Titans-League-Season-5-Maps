<TERRAIN_GENERATION>
/* color_correction CC_DESERT */

/* Covers up singleton groups of shallow terrain. */
create_terrain BASE_TERRAIN {
	base_terrain SHALLOW
	land_percent 100
	number_of_clumps 8192
	spacing_to_specific_terrain WATER 6
	spacing_to_specific_terrain ISLAND_TERRAIN 6
	spacing_to_specific_terrain CORNER_TERRAIN 6
}

/*
 * Consider adjusting forests to spawn per-player.
 * 8% with 18 clumps is 1152 tiles, at 64 tiles per clump.
 * Then each player gets 3 woodlines of 64 tiles, leaving then 12 remaining
 * clumps of 1152 - 6 * 64 = 1152 - 384 = 768.
 * Hence number_of_tiles = 768 and number_of_clumps = 12 after the player
 * forests.
 *
 * Alternatively, we can spawn 3 forests per player as lands. But that might
 * have problems given how the land is used to grow the terrain
 */

#REPEAT(8)
	create_terrain BASE_TERRAIN {
		base_terrain SNOW
		land_percent 100
		number_of_clumps 8192
		set_avoid_player_start_areas 32
	}
#END_REPEAT

create_terrain DESERT {
	base_terrain SNOW
	land_percent 100
	spacing_to_other_terrain_types 3
}

create_terrain GRASS {
	base_terrain SNOW
	land_percent 100
	spacing_to_other_terrain_types 3
	spacing_to_specific_terrain DESERT 5
}

create_terrain PALM_DESERT {
	base_terrain DESERT
	number_of_tiles (3 * 64)
	number_of_clumps 3
	set_avoid_player_start_areas 15
	spacing_to_other_terrain_types 1
}

create_terrain PALM_DESERT {
	base_terrain GRASS
	number_of_tiles (3 * 64)
	number_of_clumps 3
	set_avoid_player_start_areas 15
	spacing_to_other_terrain_types 1
}

/* Create separate forests on each side of the map. */
#REPEAT(8)
	create_terrain BASE_TERRAIN {
		base_terrain SNOW
		land_percent 100
		number_of_clumps 8192
	}
#END_REPEAT

#REPEAT(8)
	create_terrain ROAD {
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 8192
		spacing_to_specific_terrain GRASS 30
		spacing_to_specific_terrain SHALLOW 6
	}

	create_terrain ROAD2 {
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 8192
		spacing_to_specific_terrain DESERT 30
		spacing_to_specific_terrain SHALLOW 6
	}
#END_REPEAT

#REPEAT(8)
	create_terrain ROAD {
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 8192
		spacing_to_specific_terrain GRASS 15
		spacing_to_specific_terrain ROAD2 20
		spacing_to_specific_terrain SHALLOW 3
	}

	create_terrain ROAD2 {
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 8192
		spacing_to_specific_terrain DESERT 10
		spacing_to_specific_terrain ROAD 10
		spacing_to_specific_terrain SHALLOW 3
	}
#END_REPEAT

#REPEAT(8)
	create_terrain ROAD {
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 8192
		spacing_to_specific_terrain SHALLOW 3
		spacing_to_specific_terrain GRASS 8
		spacing_to_specific_terrain ROAD2 6
	}
#END_REPEAT

#REPEAT(8)
