<PLAYER_SETUP>
	direct_placement

	behavior_version 1

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif

if LOW_RESOURCES
	if NOMAD_MAP
		#define STANDARD_START
	else
		if EMPIRE_WARS
			#define STANDARD_START
		else
			#define NOMAD_START
		endif
	endif
else
	if NOMAD_MAP
		if EMPIRE_WARS
			#define STANDARD_START
		else
			#define NOMAD_START
		endif
	else
		#define STANDARD_START
	endif
endif

if NOMAD_START
	if EMPIRE_WARS
	else
		nomad_resources
	endif
else
endif

if EMPIRE_WARS
	if DARK_AGE_START
		#define EW_DARK
		effect_amount MOD_RESOURCE AMOUNT_STARTING_WOOD ATTR_SET -30
		effect_amount MOD_RESOURCE AMOUNT_STARTING_FOOD ATTR_SET -100
	elseif FEUDAL_AGE_START
		#define EW_FEUDAL
	elseif CASTLE_AGE_START
		#define EW_CASTLE
	elseif IMPERIAL_AGE_START
		#define EW_IMPERIAL
	elseif POST_IMPERIAL_AGE_START
		#define EW_POST
	else
		#define EW_DEFAULT
	endif
endif

if BIRD_A
	effect_amount SET_ATTRIBUTE BIRD_A ATTR_LINE_OF_SIGHT 0
endif

if BIRD_B
	effect_amount SET_ATTRIBUTE BIRD_B ATTR_LINE_OF_SIGHT 0
endif

if NOMAD_START
	if REGICIDE
		if CAPTURE_THE_RELIC
			#define MULTIPLE_MODES
			if REGICIDE_BUILDING
				#define FAR_MONASTERY
			endif
		endif
	endif
endif

if CENTRALISE_SPAWN	
	#define CENTRALISE_UNITS
	#define CENTRALISE_BUILDINGS
else
	if NOMAD_START
	else
		#define CENTRALISE_UNITS
	endif
endif
	#define PRELIMINARIES
if PRELIMINARIES
	if THEME_EUROPEAN
		if SIX_A
			set_gaia_civilization 1 /* British */
		elseif SIX_B
			set_gaia_civilization 2 /* French */
		elseif SIX_C
			set_gaia_civilization 4 /* Teutons */
		elseif SIX_D
			set_gaia_civilization 13 /* Celts */
		elseif SIX_E
			set_gaia_civilization 32 /* Bulgarians */
		elseif SIX_F
			set_gaia_civilization 36 /* Burgundians */
		endif
	elseif THEME_ALPINE
		if TWO_A
			set_gaia_civilization 11 /* Vikings */
		elseif TWO_B
			set_gaia_civilization 23 /* Slavs */
		endif
	elseif THEME_AMERICAN
		if THREE_A
