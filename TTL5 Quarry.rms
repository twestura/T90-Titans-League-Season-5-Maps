/* divider */	
create_land {
  terrain_type OUTSIDE_TERRAIN
  number_of_tiles 0
  base_size 5
  base_elevation 4
  if NORTHSOUTH
    land_position 50 27
    left_border 50
    right_border 49
    bottom_border 68
  elseif EASTWEST
    land_position 27 50
    right_border 68
    top_border 49
    bottom_border 50
  endif
  border_fuzziness 100
}	

create_land {
  terrain_type OUTSIDE_TERRAIN
  number_of_tiles 0
  base_size 5
  base_elevation 4
  if NORTHSOUTH
    land_position 50 73
    left_border 49
    right_border 50
    top_border 68
  elseif EASTWEST
    land_position 73 50
    left_border 68
    top_border 50
    bottom_border 49
  endif
  border_fuzziness 100
}

