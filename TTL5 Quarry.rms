#HEADER_END

/*
 * Done
 * - Outside Relics avoid forest zone by 1.
 * - Patch the occasional tile of GRASS3 in the middle of the map.
 * - Ensure all Desert/Cracked Earth layering has a Cracked Earth base.
 * - Adjust distribution of middle Deer.
 * - Ensure Berries spawn.
 * - Outside resources avoid forest zone and relics.
 * - Outside stragglers avoid outside Gold and Stone.
 * - Ensure 4 Gold groups spawn in the middle.
 * - Better balance Relic in the middle.
 * - Repeat Elevation commands to decrease outside valleys (e.g. seed 427191245)
 * - Villager positioning and straggler trees
 * - Adjust "extra" woodlines to ensure player resources spawn.
 * - Adjust placement of player Gold and Stone mines to ensure they spawn.
 * - Replace the 1-tile woodlines with reeds.
 */

/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif

#const OUTSIDE_TERRAIN 5
#const CORNER_TERRAIN 5

#const REEDS 92
#const QUARRY 914

#const PHON 1543
#const PHOFF 1902
#const TERRAIN_BLOCKER 1613

start_random
  percent_chance 50 #define NORTHSOUTH
  percent_chance 50 #define EASTWEST
end_random

/* Constants for placing Relics on specific land IDs. */
start_random
  percent_chance 50 #const RELIC_A_LAND 10
  percent_chance 50 #const RELIC_A_LAND 30
end_random

start_random
  percent_chance 50 #const RELIC_B_LAND 20
  percent_chance 50 #const RELIC_B_LAND 40
end_random
    

/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
direct_placement
ai_info_map_type GOLD_RUSH 0 0 0

/* Sets Bird Line of Sight to 0. */
effect_amount SET_ATTRIBUTE HAWK ATTR_LINE_OF_SIGHT 0

/* TTL5: Siege Tower Changes */
if BLACK_WALKABLE
else
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_GARRISON_CAPACITY -5
  effect_amount ADD_ATTRIBUTE DLC_SIEGETOWER ATTR_HITPOINTS -45
endif


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
base_terrain GRASS3
create_land {
  terrain_type DLC_CRACKED
  land_percent 1
  base_size 4
  top_border 34
  bottom_border 34
  right_border 34
  left_border 34
  land_position 50 50
  border_fuzziness 99
  zone 9
  land_id 9
}

create_land {
  terrain_type DIRT
  land_percent 100
  base_size 1
  top_border 34
  bottom_border 34
  right_border 34
  left_border 34
  border_fuzziness 99
  zone 9
}

