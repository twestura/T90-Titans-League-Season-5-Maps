/*
 * Places the Relic and the Quarry. 
 *
 * The two objects have a min distance of 1 to ensure they do not spawn directly
 * on the land's center tile. With the max distance of 2, they have the outer 24
 * tiles to spawn on, which guarantees there is room for both objects while
 * using a min distance group placement of 2.
 */
create_object QUARRY {
  set_gaia_object_only
  place_on_specific_land_id 9
  min_distance_to_players 1
  max_distance_to_players 2
  min_distance_group_placement 2
}

create_object RELIC {
  set_gaia_object_only
  place_on_specific_land_id 9
  min_distance_to_players 1
  max_distance_to_players 2
  min_distance_group_placement 2
}

/* middle gold */
create_object GOLD {
  set_gaia_object_only
  place_on_specific_land_id 9
  min_distance_to_players 0
  max_distance_to_players 5
  number_of_objects 3
  /*
   * Note there were rare cases where only 3 groups would spawn in an earlier
   * version of the map before the Quarry and Relic placements were reworked. It
   * may be worth it to use a couple of checks and retries to place these Golds.
   */
  number_of_groups 4
  set_tight_grouping
  group_placement_radius 1
  min_distance_group_placement 2
  temp_min_distance_group_placement 3
  actor_area middle_gold_5
  actor_area_radius 5
}

/* FORAGE */
/*
 * The loop is to avoid rare instances where the TC is too far away from the
 * middle for the forage bushes to spawn. The max distance to players is
 * increased by 1 each iteration. This ensures the closest distance that allows
 * the bushes to spawn is the distance that is used.
 */
#FOR($LAND_ID, 1, 3)
  #FOR($MAX_DISTANCE, 11, 15)
    create_object DLC_ORANGEBUSH {
      place_on_specific_land_id $LAND_ID
      set_gaia_object_only
      terrain_to_place_on DIRT
      min_distance_to_players 9
      max_distance_to_players $MAX_DISTANCE
      number_of_objects 4
      set_tight_grouping
      group_placement_radius 1
      actor_area forage_land_id_$LAND_ID
      actor_area_radius 1
      avoid_actor_area forage_success_$LAND_ID
    }

    create_object PHOFF {
      place_on_specific_land_id $LAND_ID
      set_gaia_object_only
      actor_area_to_place_in forage_land_id_$LAND_ID
      actor_area forage_success_$LAND_ID
      actor_area_radius 120
    }

    create_object PHOFF {
      place_on_specific_land_id $LAND_ID
      set_gaia_object_only
      avoid_actor_area forage_success_$LAND_ID
      actor_area forage_failure_11_$LAND_ID
      actor_area_radius 120
    }
  #END_FOR

  /* Adds the map's original 4 tile distance around the forage bushes. */
  create_object PHOFF {
    place_on_specific_land_id $LAND_ID
    actor_area_to_place_in forage_land_id_$LAND_ID
    set_gaia_object_only
    number_of_objects 32
    actor_area forage4
    actor_area_radius 4
  }
#END_FOR

/* Keeps Middle Relics away from the Forage bushes. */
create_object PHOFF {
  number_of_objects 999
  #SET_PLACE_FOR_EVERY_PLAYER
  set_gaia_object_only
  actor_area_to_place_in forage4
  actor_area 10000
  actor_area_radius 5
}

